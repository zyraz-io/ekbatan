---
// Global top nav.
//
// Three section links (Concepts · Learn · Reference) plus the EKBATAN logo +
// version chip on the left and a GitHub link on the right. Mirrors the
// original Lovable header's brutalist look (sticky-top paper bar, 2px ink
// border-bottom, yellow-highlighted EKBATAN swatch, all-caps mono link text).
//
// The current section gets a yellow background via .nav-current so users
// always know where they are.
interface Props {
    activeSection?: "concepts" | "learn" | "reference";
}
const { activeSection } = Astro.props;

const B = import.meta.env.BASE_URL; // trailing slash already baked in
const sections = [
    { id: "concepts", label: "Concepts", href: `${B}concepts/` },
    { id: "learn", label: "Learn", href: `${B}learn/` },
    { id: "reference", label: "Reference", href: `${B}reference/` },
] as const;
---

<header class="sticky top-0 z-50 bg-paper border-b-2 border-ink">
    <div class="container-px max-w-7xl mx-auto flex items-center justify-between py-3">
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-3 group">
            <div
                class="w-8 h-8 brut-border bg-yellow flex items-center justify-center"
            >
                <div class="w-3 h-3 bg-ink rounded-full"></div>
            </div>
            <span class="font-display text-xl font-bold tracking-tight"
                >EKBATAN</span
            >
            <span
                class="font-mono text-[10px] bg-ink text-paper px-1.5 py-0.5"
                >v0.0.3</span
            >
        </a>
        <nav
            class="hidden md:flex items-center gap-1 font-mono text-[11px] uppercase tracking-widest"
        >
            {
                sections.map((s) => (
                    <a
                        href={s.href}
                        class:list={[
                            "px-3 py-2 transition-colors",
                            activeSection === s.id
                                ? "bg-yellow"
                                : "hover:bg-yellow",
                        ]}
                    >
                        {s.label}
                    </a>
                ))
            }
        </nav>
        <details class="relative menu-details">
            <summary
                class="font-mono text-[11px] uppercase tracking-widest brut-border bg-paper px-3 py-2 cursor-pointer"
                >Menu</summary
            >
            <nav
                class="absolute right-0 top-full mt-2 flex flex-col font-mono text-[11px] uppercase tracking-widest bg-paper brut-border min-w-[160px] z-50"
            >
                {
                    sections.map((s) => (
                        <a
                            href={s.href}
                            class:list={[
                                "px-3 py-2 transition-colors border-b-2 border-ink last:border-b-0",
                                activeSection === s.id
                                    ? "bg-yellow"
                                    : "hover:bg-yellow",
                            ]}
                        >
                            {s.label}
                        </a>
                    ))
                }
            </nav>
        </details>
        <a
            href="https://github.com/zyraz-io/ekbatan"
            target="_blank"
            rel="noreferrer"
            class="font-mono text-[11px] uppercase tracking-widest brut-border bg-ink text-paper px-3 py-2 hover:bg-orange hover:text-paper transition-colors"
            >GitHub ↗</a
        >
    </div>
</header>

<style>
    /* Strip the browser-default disclosure triangle from the mobile MENU
       summary so it reads as a plain brutalist button. */
    .menu-details > summary {
        list-style: none;
    }
    .menu-details > summary::-webkit-details-marker {
        display: none;
    }
    .menu-details > summary::marker {
        content: "";
    }
    /* The frozen Lovable Tailwind bundle doesn't ship a plain `md:hidden`
       utility (only `after:md:hidden`), so we hand-roll the breakpoint
       hide here: MENU dropdown only on screens narrower than md (768px). */
    @media (min-width: 768px) {
        .menu-details {
            display: none;
        }
    }
</style>
