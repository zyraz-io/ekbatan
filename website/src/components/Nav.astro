---
// Global top nav.
//
// Two section links (Learn · Reference) plus the EKBATAN logo +
// version chip on the left and a GitHub link on the right. Mirrors the
// site's brutalist look (sticky-top paper bar, 2px ink border-bottom,
// yellow-highlighted EKBATAN swatch, all-caps mono link text).
//
// The current section gets a yellow background via .nav-current so users
// always know where they are.
interface Props {
    activeSection?: "learn" | "reference";
}
const { activeSection } = Astro.props;

const B = import.meta.env.BASE_URL; // trailing slash already baked in
const sections = [
    { id: "learn", label: "Learn", href: `${B}learn/` },
    { id: "reference", label: "Reference", href: `${B}reference/` },
] as const;
---

<header class="sticky top-0 z-50 bg-paper border-b-2 border-ink">
    <div class="container-px max-w-7xl mx-auto flex items-center justify-between py-3">
        <a
            href={import.meta.env.BASE_URL}
            class="nav-brand flex items-center gap-3 group"
        >
            <div
                class="nav-logo w-8 h-8 brutalist-border bg-yellow flex items-center justify-center"
            >
                <div class="nav-logo-dot w-3 h-3 bg-ink rounded-full"></div>
            </div>
            <span
                class="nav-brand-title font-display text-xl font-bold tracking-tight"
                >EKBATAN</span
            >
            <span
                class="nav-version font-mono text-[10px] bg-ink text-paper px-1.5 py-0.5"
                >v0.2.1</span
            >
        </a>
        <nav
            class="hidden md:flex items-center gap-1 font-mono text-[11px] uppercase tracking-widest"
        >
            {
                sections.map((s) => (
                    <a
                        href={s.href}
                        class:list={[
                            "px-3 py-2 transition-colors",
                            activeSection === s.id
                                ? "bg-yellow"
                                : "hover:bg-yellow",
                        ]}
                    >
                        {s.label}
                    </a>
                ))
            }
        </nav>
        <details class="relative menu-details">
            <summary
                class="menu-summary font-mono text-[11px] uppercase tracking-widest brutalist-border bg-paper px-3 py-2 cursor-pointer"
                >Menu</summary
            >
            <nav
                class="absolute right-0 top-full mt-2 flex flex-col font-mono text-[11px] uppercase tracking-widest bg-paper brutalist-border min-w-[160px] z-50"
            >
                {
                    sections.map((s) => (
                        <a
                            href={s.href}
                            class:list={[
                                "px-3 py-2 transition-colors border-b-2 border-ink last:border-b-0",
                                activeSection === s.id
                                    ? "bg-yellow"
                                    : "hover:bg-yellow",
                            ]}
                        >
                            {s.label}
                        </a>
                    ))
                }
            </nav>
        </details>
        <a
            href="https://github.com/zyraz-io/ekbatan"
            target="_blank"
            rel="noreferrer"
            class="nav-github font-mono text-[11px] uppercase tracking-widest brutalist-border bg-ink text-paper px-3 py-2 hover:bg-orange hover:text-paper transition-colors"
            >GitHub <span class="nav-github-arrow">↗</span></a
        >
    </div>
</header>

<style>
    /* Strip the browser-default disclosure triangle from the mobile MENU
       summary so it reads as a plain brutalist button. */
    .menu-details > summary {
        list-style: none;
    }
    .menu-details > summary::-webkit-details-marker {
        display: none;
    }
    .menu-details > summary::marker {
        content: "";
    }
    header .nav-github {
        align-items: center;
        display: inline-flex;
        letter-spacing: 0.08em;
        padding-left: 0.5rem;
        padding-right: 0.5rem;
        white-space: nowrap;
    }
    @media (max-width: 479px) {
        header .nav-brand {
            gap: 0.375rem;
        }
        header .nav-logo {
            height: 1.5rem;
            width: 1.5rem;
        }
        header .nav-logo-dot {
            height: 0.5rem;
            width: 0.5rem;
        }
        header .nav-brand-title {
            font-size: 1rem;
            line-height: 1;
        }
        header .nav-version {
            font-size: 9px;
            padding: 0.0625rem 0.25rem;
        }
        header .menu-summary {
            letter-spacing: 0.06em;
            padding-left: 0.5rem;
            padding-right: 0.5rem;
        }
        header .nav-github .nav-github-arrow {
            display: none;
        }
        header .nav-github {
            letter-spacing: 0.04em;
            padding-left: 0.375rem;
            padding-right: 0.375rem;
        }
    }
    /* The frozen Tailwind bundle doesn't ship a plain `md:hidden` utility
       (only `after:md:hidden`), so we hand-roll the breakpoint hide here:
       MENU dropdown only on screens narrower than md (768px). */
    @media (min-width: 768px) {
        .menu-details {
            display: none;
        }
        header .nav-github {
            letter-spacing: 0.1em;
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }
    }
</style>

<script>
    const menuDetails = document.querySelector<HTMLDetailsElement>(".menu-details");

    document.addEventListener("pointerdown", (event) => {
        if (!menuDetails?.open) {
            return;
        }

        if (
            event.target instanceof Node &&
            !menuDetails.contains(event.target)
        ) {
            menuDetails.open = false;
        }
    });

    document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && menuDetails?.open) {
            menuDetails.open = false;
        }
    });
</script>
