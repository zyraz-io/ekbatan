---
// Wrapper layout for MDX pages under /concepts/, /learn/, /reference/.
//
// MDX frontmatter (title, description, activeSection) is automatically
// supplied by Astro on Astro.props.frontmatter — we unpack it here and pass
// through to BaseLayout so the MDX files only need plain frontmatter, no
// imports.
//
// Adds minimal "prose" styling for MDX-emitted <h1>/<h2>/<h3>/<p>/<pre>/
// <code>/<ul>/<a>/<blockquote> — the Tailwind bundle is frozen (no
// @tailwindcss/typography), so the styling lives here as inline CSS scoped
// to .doc-prose. Brutalist palette: paper bg, ink borders, JetBrains Mono for
// code, Space Grotesk for headings.
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout
    title={frontmatter.title}
    description={frontmatter.description}
    activeSection={frontmatter.activeSection}
>
    <article class="doc-prose container-px max-w-4xl mx-auto py-12 md:py-20">
        <header class="mb-12 pb-8 border-b-2 border-ink">
            <div class="inline-flex items-center gap-3 brutalist-border bg-ink text-paper font-mono text-[11px] uppercase tracking-widest px-3 py-1.5">
                <span class="text-yellow">§</span>
                <span>{frontmatter.activeSection ?? "page"}</span>
            </div>
            <h1
                class="font-display font-bold text-4xl md:text-6xl tracking-tight mt-6 leading-[0.95] text-balance"
            >
                {frontmatter.title}
            </h1>
            {
                frontmatter.lead && (
                    <p class="mt-4 text-lg leading-relaxed text-muted-foreground max-w-2xl">
                        {frontmatter.lead}
                    </p>
                )
            }
        </header>
        <slot />
    </article>
</BaseLayout>

<style is:global>
    .doc-prose {
        font-family: "DM Sans", system-ui, sans-serif;
        line-height: 1.7;
    }
    .doc-prose h2 {
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: clamp(1.75rem, 3vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-top: 3rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--ink, #0a0a0a);
    }
    .doc-prose h3 {
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.015em;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
    }
    .doc-prose h4 {
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-size: 1.15rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
    }
    .doc-prose p {
        margin-block: 1rem;
    }
    .doc-prose a {
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 3px;
        text-decoration-color: var(--brand-orange, #ff6633);
    }
    .doc-prose a:hover {
        background: var(--brand-yellow, #ffd23f);
        color: var(--ink, #0a0a0a);
    }
    .doc-prose ul,
    .doc-prose ol {
        margin-block: 1rem;
        padding-left: 1.5rem;
    }
    .doc-prose ul {
        list-style: square;
    }
    .doc-prose ol {
        list-style: decimal;
    }
    .doc-prose li {
        margin-block: 0.35rem;
    }
    .doc-prose blockquote {
        border-left: 4px solid var(--brand-orange, #ff6633);
        padding: 0.5rem 1rem;
        margin: 1.25rem 0;
        font-style: italic;
    }
    /* Inline <code> inside paragraphs */
    .doc-prose :not(pre) > code {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.9em;
        background: var(--brand-yellow, #ffd23f);
        padding: 0 0.25rem;
        border: 1px solid var(--ink, #0a0a0a);
    }
    /* Shiki code fences are wrapped in <pre class="astro-code">. */
    .doc-prose pre {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.85rem;
        line-height: 1.55;
        border: 2px solid var(--ink, #0a0a0a);
        box-shadow: 4px 4px 0 0 var(--ink, #0a0a0a);
        padding: 1rem 1.25rem;
        margin: 1.5rem 0;
        overflow-x: auto;
        background: #fafafa;
        position: relative; /* anchor for the floating copy button */
    }
    /* The script below wraps every Shiki fence in a .code-fence-wrap div and
       puts the copy button INSIDE that wrap (not inside the <pre>) — because
       absolute children of an overflow:auto element scroll with the content
       when the user drags a long line horizontally, which makes the button
       drift right. The wrap is a static, non-scrolling parent so the button
       stays pinned to the visible top-right. The wrap inherits the brutalist
       chrome (border + shadow + margin) that previously sat on the <pre>;
       the <pre> itself now just provides the scroll context and padding. */
    .doc-prose .code-fence-wrap {
        position: relative;
        margin: 1.5rem 0;
        border: 2px solid var(--ink, #0a0a0a);
        box-shadow: 4px 4px 0 0 var(--ink, #0a0a0a);
        background: #fafafa;
    }
    .doc-prose .code-fence-wrap > pre.astro-code {
        margin: 0;
        border: 0;
        box-shadow: none;
    }
    .doc-prose .code-fence-wrap > .copy-btn-floating {
        position: absolute;
        top: 0.4rem;
        right: 0.6rem;
        z-index: 1;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink, #0a0a0a);
        background: rgba(250, 250, 250, 0.85);
        padding: 0.1rem 0.35rem;
        border: 0;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.15s ease, color 0.15s ease;
    }
    .doc-prose .code-fence-wrap:hover > .copy-btn-floating,
    .doc-prose .code-fence-wrap > .copy-btn-floating:focus,
    .doc-prose .code-fence-wrap > .copy-btn-floating.copied {
        opacity: 1;
    }
    .doc-prose .code-fence-wrap > .copy-btn-floating:hover,
    .doc-prose .code-fence-wrap > .copy-btn-floating.copied,
    .doc-prose .code-fence-wrap > .copy-btn-floating.copied:hover {
        color: var(--brand-orange);
    }
    /* The <CodeBlock> component brings its OWN brutalist-border + brutalist-shadow on its
       outer wrapper, so its inner <pre> shouldn't get the standalone-pre chrome
       above (otherwise you get a box-in-a-box-with-shadow effect). Strip the
       border/shadow/margin from any <pre> that lives inside a .brutalist-border
       wrapper — the CodeBlock's wrapper handles all of that. */
    .doc-prose .brutalist-border pre {
        border: 0;
        box-shadow: none;
        margin: 0;
        background: transparent;
    }
    /* Give the CodeBlock outer wrapper the same vertical breathing room standalone
       fenced blocks get. Restricted to .bg-paper so it doesn't also widen the
       section-name chip in the header (which uses brutalist-border + bg-ink and
       wants no extra vertical margin). */
    .doc-prose .brutalist-border.bg-paper {
        margin: 1.5rem 0;
    }
    /* The "compile error" wavy red underline — used to mark identifiers that
       reference code that doesn't exist yet (e.g. jOOQ-generated classes
       before codegen runs). Same visual as IntelliJ / VS Code's diagnostic
       squiggle, so readers recognize it instantly. */
    .compile-error {
        text-decoration: underline wavy #ef4444;
        text-decoration-thickness: 1.5px;
        text-underline-offset: 3px;
    }
    .doc-prose pre code {
        font-family: inherit;
        background: transparent;
        padding: 0;
        border: 0;
    }
    .doc-prose hr {
        border: 0;
        border-top: 2px solid var(--ink, #0a0a0a);
        margin: 2.5rem 0;
    }
    .doc-prose table {
        border-collapse: collapse;
        width: 100%;
        margin: 1.5rem 0;
        font-size: 0.9rem;
    }
    .doc-prose th,
    .doc-prose td {
        border: 2px solid var(--ink, #0a0a0a);
        padding: 0.5rem 0.75rem;
        text-align: left;
        vertical-align: top;
    }
    .doc-prose th {
        background: var(--brand-yellow, #ffd23f);
        font-family: "Space Grotesk", system-ui, sans-serif;
        font-weight: 700;
    }
</style>

<script>
    // Inject a Copy button into every Shiki-rendered fence on the page so
    // markdown ```code blocks get the same copy UX as <CodeBlock> components
    // without each .mdx file having to opt in manually. Skips fences that
    // already live inside a CodeBlock wrapper (which ships its own button).
    document
        .querySelectorAll<HTMLPreElement>(".doc-prose pre.astro-code")
        .forEach((pre) => {
            // CodeBlock wraps its <pre> in a .brutalist-border outer div; that
            // outer div already provides its own copy button so skip those.
            if (pre.closest(".brutalist-border")) return;
            const code = pre.textContent ?? "";
            // Wrap the <pre> in a non-scrolling div so the absolute-positioned
            // copy button doesn't drift right when the user scrolls a long
            // line horizontally (position:absolute children of an overflow:auto
            // element scroll with the content). The wrapper carries the brut
            // chrome; the inner <pre> just provides the scroll context.
            const wrap = document.createElement("div");
            wrap.className = "code-fence-wrap";
            pre.parentNode?.insertBefore(wrap, pre);
            wrap.appendChild(pre);
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "copy-btn-floating";
            btn.textContent = "Copy";
            btn.setAttribute("aria-label", "Copy code");
            btn.addEventListener("click", async () => {
                try {
                    await navigator.clipboard.writeText(code);
                } catch {
                    // Fallback for non-HTTPS contexts / older browsers
                    const ta = document.createElement("textarea");
                    ta.value = code;
                    ta.style.position = "fixed";
                    ta.style.opacity = "0";
                    document.body.appendChild(ta);
                    ta.select();
                    try { document.execCommand("copy"); } catch {}
                    document.body.removeChild(ta);
                }
                btn.textContent = "Copied";
                btn.classList.add("copied");
                setTimeout(() => {
                    btn.textContent = "Copy";
                    btn.classList.remove("copied");
                }, 1500);
            });
            wrap.appendChild(btn);
        });
</script>
