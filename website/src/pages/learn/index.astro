---
// /learn/ — the main reading path. Starts with the guided introduction,
// then moves through the core model, practical tutorials, and finally the
// full project setup guide.
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionCard from "../../components/SectionCard.astro";

// Prefix the absolute hrefs in the entries data with the deployment base path
// at render time. Lets the source list stay as readable root-relative paths.
const linkTo = (p: string) => `${import.meta.env.BASE_URL}${p.replace(/^\//, "")}`;

const lessons = [
    {
        href: "/learn/getting-started/",
        title: "Getting started",
        blurb: "Start here. Follow one wallet change through the dual-write problem, Model events, Action staging, executor commit, and post-commit consumption.",
        status: "ready",
    },
    {
        href: "/learn/the-dual-write-trap/",
        title: "The dual-write trap",
        blurb: "Why writing to a database and to Kafka separately creates silent drift, and why the event must be stored with the state first.",
        status: "ready",
    },
    {
        href: "/learn/outbox/",
        title: "The outbox: atomic state + events",
        blurb: "How Ekbatan commits domain rows and event rows together, so the database contains both the state and the fact that changed it.",
        status: "ready",
    },
    {
        href: "/learn/models-and-entities/",
        title: "Models and Entities",
        blurb: "Models emit events when they change; Entities don't. Learn which shape to use and how immutable mutations work.",
        status: "ready",
    },
    {
        href: "/learn/actions/",
        title: "Actions, ActionPlan, ActionExecutor",
        blurb: "The two-phase lifecycle: build the new state first, then let the executor commit domain rows and event rows in one transaction.",
        status: "ready",
    },
    {
        href: "/learn/your-first-action/",
        title: "Your first Action",
        blurb: "Build a wallet deposit Action end-to-end: define the Model, attach an Event, wire the Action, run it through an ActionExecutor.",
        status: "ready",
    },
    {
        href: "/learn/consuming-events/",
        title: "Consuming events",
        blurb: "Use persisted events after commit: handle them in the same service, publish from a handler, stream with CDC, or route one raw stream into many broker topics.",
        status: "ready",
    },
    {
        href: "/learn/sharding/",
        title: "Adding a shard",
        blurb: "Take a single-database service to two shards using EmbeddedBitsShardingStrategy. Your action signatures don't change.",
        status: "ready",
    },
    {
        href: "/learn/sharding-strategies/",
        title: "Sharding strategies",
        blurb: "The deeper model behind groups, members, embedded-bits IDs, custom routing, and why cross-shard actions need care.",
        status: "ready",
    },
    {
        href: "/learn/sagas/",
        title: "Sagas",
        blurb: "Split multi-step workflows into committed actions chained by events, with explicit compensation when a later step fails.",
        status: "ready",
    },
    {
        href: "/learn/native-image/",
        title: "Compiling to a native binary",
        blurb: "Add the ekbatan-native dependency, declare your scan packages, include migration resources, and run the native build/test path for your stack.",
        status: "ready",
    },
    {
        href: "/learn/complete-project-setup/",
        title: "Complete project setup",
        blurb: "The full stack/build/database setup matrix: scaffold, dependencies, Flyway migrations, jOOQ codegen, DB config, startup migrator, examples, and verification.",
        status: "ready",
    },
] as const;
---

<BaseLayout
    title="Learn · Ekbatan"
    description="A progressive learning path first, then the full setup matrix when you are ready to wire a real project."
    activeSection="learn"
>
    <section class="border-b-2 border-ink">
        <div class="container-px max-w-7xl mx-auto py-20 md:py-28">
            <div class="inline-flex items-center gap-3 brutalist-border bg-ink text-paper font-mono text-[11px] uppercase tracking-widest px-3 py-1.5">
                <span class="text-yellow">§</span><span>Learn</span>
            </div>
            <h1 class="font-display font-bold text-5xl md:text-7xl tracking-tight max-w-4xl text-balance mt-6 leading-[0.95]">
                Learn the model.
                <span class="bg-orange text-paper px-2">Then build.</span>
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-relaxed">
                Start with the problem Ekbatan solves, then learn the core
                model, write an Action, consume persisted events, add sharding,
                and look at native-image. When you are ready to wire a real
                application, the complete setup guide keeps the detailed project
                setup in one place.
            </p>
            <div class="mt-14 grid md:grid-cols-2 gap-5">
                {
                    lessons.map((l, i) => (
                        <SectionCard
                            href={linkTo(l.href)}
                            title={l.title}
                            blurb={l.blurb}
                            status={l.status}
                            index={String(i + 1).padStart(2, "0")}
                        />
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>
