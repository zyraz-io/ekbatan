     modern engine. The glow is the #bw-glow-fail SVG filter, which blurs
     SourceGraphic so the halo colour tracks the animated stroke colour. */
  .broken-wires .signal-fail {
    fill: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .broken-wires .signal {
      display: none;
    }
  }
