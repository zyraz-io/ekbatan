     desktop look doesn't read well in a single narrow column. */
  @media (max-width: 767px) {
    #top > div {
      padding-top: 2rem !important;
    }
    .hero-h1 {
      text-align: center;
    }
  }
  /* On desktop, vertically center the hero in the viewport. The inline
     padding-top:10rem on the outer div was pushing content downward; with a
     flex column + justify-center, the content sits in the middle of the
     min-height area (100vh - 4rem header). Padding kept at 2rem so content
     never butts up against the header bar on shorter laptop screens. */
  @media (min-width: 1024px) {
    #top > div {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 2rem !important;
      padding-bottom: 2rem !important;
    }
    #top > div > div {
      margin-top: 0 !important;
    }
  }

  /* Problem-section layout: 4 cells (left text + diagram, right text + diagram).
     Mobile stacks them text-L → diag-L → text-R → diag-R so each side stays
     together. Desktop becomes a 2x2 grid where the two diagrams share the same
     row — that row stretches both cards to the taller card's height, matching
     the original side-by-side layout. */
  .problem-grid {
    display: grid;
    grid-template-areas:
      "cell-left-text"
      "cell-left-diagram"
      "cell-right-text"
      "cell-right-diagram";
