    }
    93% {
      d: path("M -1 0 L -0.83 2 L -0.67 0 L -0.5 -2 L -0.33 0 L -0.17 2 L 0 0 L 0.17 -2 L 0.33 0 L 0.5 2 L 0.67 0 L 0.83 -2 L 1 0");
    }
    100% {
      d: path("M 0 0 L 0 0 L 0 0 L 0 0 L 0 0 L 0 0 L 0 0 L 0 0 L 0 0 L 0 0 L 0 0 L 0 0 L 0 0");
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .diagram .signal {
      display: none;
    }
  }
