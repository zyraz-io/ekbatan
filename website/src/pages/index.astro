</section>
</BaseLayout>

<style>
  /* The Lovable Tailwind bundle was tree-shaken from the original HTML, so
     arbitrary values (lg:grid-cols-[1.8fr_1fr], lg:text-[7.5rem], etc.) are
     not in the CSS. Anything we set here is the documented escape hatch. */

  .hero-h1 {
    font-size: 8.97vw;
    line-height: 0.9;
    letter-spacing: -0.04em;
    text-align: right;
  }
  @media (min-width: 768px) {
    .hero-h1 { font-size: 7.11vw; }
  }
  @media (min-width: 1024px) {
    .hero-h1 { font-size: 4.5rem; }
  }
  /* On mobile, pull the hero up (kill the desktop-sized 10rem top padding
     baked inline on #top's inner div) and center the title — the right-aligned
     desktop look doesn't read well in a single narrow column. */
  @media (max-width: 767px) {
    #top > div {
      padding-top: 2rem !important;
    }
    .hero-h1 {
      text-align: center;
    }
  }
  /* On desktop, vertically center the hero in the viewport. The inline
     padding-top:10rem on the outer div was pushing content downward; with a
     flex column + justify-center, the content sits in the middle of the
     min-height area (100vh - 4rem header). Padding kept at 2rem so content
     never butts up against the header bar on shorter laptop screens. */
  @media (min-width: 1024px) {
    #top > div {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 2rem !important;
      padding-bottom: 2rem !important;
    }
    #top > div > div {
      margin-top: 0 !important;
    }
  }

  /* Dual-write trap diagram. Brutalist SVG: ink-stroked rects + wires + a
     "signal" circle that travels along each wire via SMIL <animateMotion>.
     The broken diagram has one signal that fades out around 45-60% of its
     journey to Kafka — visually selling the "lost in the gap between writes"
     failure mode. The signal pulses get a multi-layer drop-shadow for a soft
     orange glow. SMIL animations can't be disabled via CSS, so for users with
     prefers-reduced-motion we hide the signal circles entirely (the wires +
     boxes still tell the story statically). */
  .diagram {
    width: 100%;
    max-width: 340px;
    height: auto;
    display: block;
  }
  .diagram .wire,
  .flow-wire .wire {
    stroke: var(--ink, #0a0a0a);
    stroke-width: 2;
    fill: none;
  }
  /* Small inline SVG used between stacked boxes on the Ekbatan-side panel
     (APP → DATABASE, etc). Reuses the .wire and .signal element classes from
     the main diagram so the look is consistent. The `!important` cancels
     the parent's `space-y-4` margin so the wire visually butts up against
     the box above and below — otherwise there's a 16px gap on each side
     that breaks the illusion of a continuous connection. */
  .flow-wire {
    width: 50px;
    height: 70px;
    display: block;
    margin: -1rem auto 0 !important;
    /* Let the signal render past the SVG bounds into the APP/DATABASE/KAFKA
       box areas. Combined with .flow-box (position:relative; z-index:1) on
       the boxes, the signal renders BEHIND them — so visually it "lurks
       under" the box as it enters and emerges, without any opacity fade. */
    overflow: visible;
  }
  /* APP, DATABASE, KAFKA on the Ekbatan-side panel paint ON TOP of the
     SVG wires. position:relative is what enables z-index on flex items. */
  .flow-box {
    position: relative;
    z-index: 1;
  }
  .diagram .box rect {
    fill: var(--paper, #fafafa);
    stroke: var(--ink, #0a0a0a);
    stroke-width: 2;
  }
  .diagram .box text {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    text-anchor: middle;
    fill: var(--ink, #0a0a0a);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    dominant-baseline: middle;
  }
  .diagram .signal,
  .flow-wire .signal {
    fill: #22c55e;
    filter: drop-shadow(0 0 4px #22c55e)
            drop-shadow(0 0 10px #22c55e);
  }
  /* Per-box outcome labels sitting just below each box. Ok = neutral ink,
     fail = red — visually summarises the broken story: state landed in the
     DB, the matching event never reached Kafka. */
  .diagram .label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    text-anchor: middle;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    dominant-baseline: middle;
  }
  .diagram .label-ok {
    fill: var(--ink, #0a0a0a);
  }
  .diagram .label-fail {
    fill: #ef4444;
  }
  /* The Kafka-bound signal narrative across one 2.4s cycle:
       0–25 %  travelling green
       25–35 % transitioning green → red (this CSS keyframes block)
       35–50 % red, finishing its travel to the 75 %-of-path stopping point
              (animateMotion holds keyPoint=0.75 from 50 %–100 %)
       50–58 % red, dead-stopped at the failure point
       58–80 % decaying sinusoidal wobble (signal-fail-wobble below) — the
              "trembling before it dies" beat the user asked for
       80 %    instant vanish (opacity SMIL on the rect drops to 0 here)
     CSS animations target the rect; the rect's transform applies in the
     coordinate space rotated by animateMotion (rotate="auto"), so
     translateY = perpendicular to wire direction. */
  /* The kafka-bound signal is a <path>, not a <rect>, so we can animate its
     `d` attribute through progressively wavier sine-wave shapes (the SMIL
     <animate> on the path handles that). With stroke-width 3 and a flat
     initial path it renders identically to the DB-bound rect (looks like a
     20×3 line) — then morphs into a wavy ribbon as the path's Y coordinates
     animate. Since it's a stroked path (not filled), the colour animation
     here targets `stroke` (not `fill`). */
  /* Cycle = 3 s. DB plays first (0–33 %), then Kafka plays (33–100 %).
     All Kafka keyframe percentages below are the original 0–85 % spread
     remapped into the 33–100 % window via: new = 33 + old × 0.788. */
  .diagram .signal-fail {
    fill: none;
    animation:
      signal-fail-color 3s linear infinite,
      signal-fail-morph 3s linear infinite;
  }
  @keyframes signal-fail-color {
    0%, 53% {
      stroke: #22c55e;
      filter: drop-shadow(0 0 4px #22c55e) drop-shadow(0 0 10px #22c55e);
    }
    61%, 72% {
      stroke: #ef4444;
      filter: drop-shadow(0 0 4px #ef4444) drop-shadow(0 0 10px #ef4444);
    }
    /* During the collapse phase (72 → 100 %) the stroke fades to transparent
       and both drop-shadow halos collapse to zero blur, so the "energy" of
       the wave dies in lockstep with the shrinking geometry. */
    100% {
      stroke: rgba(239, 68, 68, 0);
      filter: drop-shadow(0 0 0 transparent) drop-shadow(0 0 0 transparent);
    }
  }
  /* Morph the path shape via the CSS `d` property (SVG2 / CSS Motion Path L1) —
     avoids the Chromium SMIL <animate attributeName="d"> reliability quirk.
     The wave forms WHILE the signal is still travelling along the wire: the
     animateMotion takes 0–50 % of the cycle to move from 0 → 75 % of the
     path, and the morph below runs from 33 % (signal hits 50 % of wire) up
     to 49 % (signal hits 75 % of wire), at which point the opacity SMIL
     above instantly hides the signal. */
  /* Two phases:
     - Growth (33–49 %): line shrinks 20 → 16 → 12 → 8 while waves intensify
       (1 → 2 → 3 cycles, amp 5 → 7 → 11). Wave climaxes at 49 %.
     - Collapse (49–85 %): line continues shrinking 8 → 6 → 4 → 2 → 0 with
       wave amp damping in parallel (11 → 7 → 4 → 2 → 0). The point arrives
       at the origin (zero size) by 85 %, then the opacity SMIL above formally
       hides the (already invisible) point so any browser stroke-dot artifact
       on a zero-length path is suppressed.
     All states keep the same 13-point M+12L structure so CSS interpolates
     `d` smoothly between them. */
  @keyframes signal-fail-morph {
    0%, 59% {
      d: path("M -10 0 L -8.33 0 L -6.67 0 L -5 0 L -3.33 0 L -1.67 0 L 0 0 L 1.67 0 L 3.33 0 L 5 0 L 6.67 0 L 8.33 0 L 10 0");
    }
    64% {
      d: path("M -8 0 L -6.67 2.5 L -5.33 4.3 L -4 5 L -2.67 4.3 L -1.33 2.5 L 0 0 L 1.33 -2.5 L 2.67 -4.3 L 4 -5 L 5.33 -4.3 L 6.67 -2.5 L 8 0");
    }
    68% {
      d: path("M -6 0 L -5 6.9 L -4 6.9 L -3 0 L -2 -6.9 L -1 -6.9 L 0 0 L 1 6.9 L 2 6.9 L 3 0 L 4 -6.9 L 5 -6.9 L 6 0");
    }
    72% {
      d: path("M -4 0 L -3.33 11 L -2.67 0 L -2 -11 L -1.33 0 L -0.67 11 L 0 0 L 0.67 -11 L 1.33 0 L 2 11 L 2.67 0 L 3.33 -11 L 4 0");
    }
    79% {
      d: path("M -3 0 L -2.5 7 L -2 0 L -1.5 -7 L -1 0 L -0.5 7 L 0 0 L 0.5 -7 L 1 0 L 1.5 7 L 2 0 L 2.5 -7 L 3 0");
