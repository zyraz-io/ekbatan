  .hero-h1 {
    font-size: 8.97vw;
    line-height: 0.9;
    letter-spacing: -0.04em;
    text-align: right;
  }
  @media (min-width: 768px) {
    .hero-h1 { font-size: 7.11vw; }
  }
  @media (min-width: 1024px) {
    .hero-h1 { font-size: 4.5rem; }
  }
  /* On mobile, pull the hero up (kill the desktop-sized 10rem top padding
