  }
  .problem-grid .cell-left-text { grid-area: cell-left-text; }
  .problem-grid .cell-left-diagram { grid-area: cell-left-diagram; }
  .problem-grid .cell-right-text { grid-area: cell-right-text; }
  .problem-grid .cell-right-diagram { grid-area: cell-right-diagram; }
