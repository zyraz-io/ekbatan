  .problem-grid .cell-right-diagram > div {
    height: 100%;
  }
  @media (min-width: 768px) {
    .problem-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "cell-left-text cell-right-text"
        "cell-left-diagram cell-right-diagram";
    }
  }

  /* Dual-write trap — left "two writes" diagram. Built from the same material
     as the right-hand panel: HTML <div> boxes (brutalist-border + bg-paper)
     for APP / DB / KAFKA / CONSUMER, positioned absolutely in a triangle, and
     an SVG overlay (.broken-wires) used ONLY for the wires + the travelling
     signals. The boxes sit at z-index:1 with an opaque background, so each
     wire and signal "lurks under" the box at its endpoints — the same trick
     the right panel uses. The signals travel via SMIL <animateMotion>; the
     Kafka-bound one fizzles out before arriving, selling the "lost in the
     gap" failure. */
  .broken-layout {
    position: relative;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 360 / 410;
  }
  /* SVG overlay holding the three wires + the two travelling signals.
     overflow:visible lets a signal render a touch past a wire endpoint; the
     boxes (painted on top) cover it instead of the SVG clipping it. */
  .broken-wires {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  /* The four boxes — absolutely positioned by their CENTRE (translate -50%).
     z-index:1 + opaque bg means a wire running box-centre to box-centre is
     covered wherever it passes under a box. width matches the right panel's
     flow-box-eq (8rem), so both diagrams use identically sized boxes. */
  .broken-box {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 8rem;
  }
  .broken-app      { left: 50%; top: 10%; }
  .broken-db       { left: 19%; top: 50%; }
  .broken-kafka    { left: 81%; top: 50%; }
  .broken-consumer { left: 81%; top: 82%; }
  /* Outcome labels pinned just below their box (top:100% = box bottom edge).
     The fail labels carry a yellow highlight that also masks the wire they
     overlap; the ok label is plain ink text. */
  .broken-label {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 8px;
    white-space: nowrap;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .broken-label-ok {
    color: var(--ink, #0a0a0a);
  }
  .broken-label-fail {
    color: #ef4444;
    background: var(--brand-yellow);
    padding: 1px 5px;
  }
  .broken-wires .wire,
  .flow-wire .wire {
    stroke: var(--ink, #0a0a0a);
    stroke-width: 2;
    fill: none;
