# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Text files
*.java text eol=lf
*.kt text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.class binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
*.svg binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# Platform-specific line endings
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
